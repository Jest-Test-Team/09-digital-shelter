{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/digital-shelter/event.schema.json",
  "title": "Digital Shelter Evidence Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "project",
    "source",
    "observed_at",
    "metric",
    "value",
    "schema_version"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "const": "digital-shelter"
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "metric": {
      "enum": [
        "critical_journey_availability",
        "degradation_time",
        "dependency_survivability",
        "containment_score",
        "recovery_point_gap"
      ]
    },
    "value": {
      "type": "number"
    },
    "unit": {
      "type": "string"
    },
    "evidence_ref": {
      "type": "string"
    },
    "schema_version": {
      "const": "0.1.0"
    },
    "attributes": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "boolean",
          "null"
        ]
      }
    }
  }
}
